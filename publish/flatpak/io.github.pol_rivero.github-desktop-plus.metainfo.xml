<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.pol_rivero.github-desktop-plus</id>
  <name>Desktop Plus</name>
  <summary>Git client with advanced functionality and Bitbucket, GitLab integration</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <developer id="io.github.pol_rivero">
    <name>Pol Rivero</name>
  </developer>
  <description>
    <p>
      This is an up-to-date fork of GitHub Desktop, with many quality of life improvements and advanced features for power users.
    </p>
    <p>See https://github.com/DesktopPlus/desktop-plus for a full list of added features.</p>
  </description>
  <url type="homepage">https://github.com/DesktopPlus/desktop-plus</url>
  <url type="vcs-browser">https://github.com/DesktopPlus/desktop-plus</url>
  <url type="bugtracker">https://github.com/DesktopPlus/desktop-plus/issues</url>
  <launchable type="desktop-id">io.github.pol_rivero.github-desktop-plus.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/DesktopPlus/desktop-plus/fd22fd8dca8dc59f2a9329d35618a36da55980e7/docs/assets/flathub/search.webp</image>
      <caption>Search for commits by title, message, tag, or hash</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/DesktopPlus/desktop-plus/fd22fd8dca8dc59f2a9329d35618a36da55980e7/docs/assets/flathub/stashes.webp</image>
      <caption>Create several stashes per branch</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/DesktopPlus/desktop-plus/fd22fd8dca8dc59f2a9329d35618a36da55980e7/docs/assets/flathub/push.webp</image>
      <caption>Easily identify unpushed branches</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/DesktopPlus/desktop-plus/fd22fd8dca8dc59f2a9329d35618a36da55980e7/docs/assets/flathub/up-to-date.webp</image>
